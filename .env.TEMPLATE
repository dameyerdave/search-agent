# ─────────────────────────────────────────────────────────────
# Environment & Docker Compose
# ─────────────────────────────────────────────────────────────
APP_ENV=dev
COMPOSE_PROFILES=dev,celery
COMPOSE_FILE=docker-compose.yml
COMPOSE_PROJECT_NAME=search-agent
GIT_VERSION=
GIT_BRANCH=
GIT_LASTCOMMITDATE=

# ─────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=54377
POSTGRES_DB=search_agent
POSTGRES_USER=search_agent
POSTGRES_PASSWORD=secret

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379

# ─────────────────────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=fsex.settings
DJANGO_SECRET_KEY=kjsdhfkajsdhfkewiucjniuecniw-sldkjnejwrnvkjwrn-sodcnwojcnwijnc
DJANGO_DEBUG=True
DJANGO_LOG_LEVEL=DEBUG
DJANGO_LOG_SQL=False
DJANGO_PORT=5000
DJANGO_HOST_PORT=5077

# Security
DJANGO_ALLOWED_HOSTS=localhost,api,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8077,http://127.0.0.1:8077,http://api:5000
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8077,http://127.0.0.1:8077,http://api:5000
DJANGO_SESSION_COOKIE_SAMESITE=Lax

# Superuser (created on first run)
DJANGO_SU_NAME=admin
DJANGO_SU_EMAIL=
DJANGO_SU_PASSWORD=admin

# Cloudflare Access
CLOUDFLARE_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com
CLOUDFLARE_ACCESS_APP_DOMAIN=app.yourdomain.com
CLOUDFLARE_ACCESS_AUDIENCE=
CLOUDFLARE_ACCESS_REDIRECT_URL=/
CLOUDFLARE_ACCESS_JWKS_CACHE_TTL_S=300

# Dev-only: when DJANGO_DEBUG=True, every API request is auto-authenticated
# as a user with this email (created on first use). Leave empty to require
# real Cloudflare Access tokens even in debug mode.
DEV_AUTO_LOGIN_EMAIL=test@test.com

# ─────────────────────────────────────────────────────────────
# Web Push / VAPID  (generate keys: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_pem())")
# Private key: PEM with literal \n escapes on one line
# Public key: uncompressed EC point, URL-safe base64url (no padding)
# ─────────────────────────────────────────────────────────────
VAPID_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n<base64>\n-----END PRIVATE KEY-----\n
VAPID_PUBLIC_KEY=<urlsafe-base64url-no-padding>
VAPID_CLAIMS_EMAIL=mailto:admin@yourdomain.com

# ─────────────────────────────────────────────────────────────
# Frontend (Nuxt)
# ─────────────────────────────────────────────────────────────
NUXT_PUBLIC_API_URL=
NUXT_PUBLIC_VAPID_PUBLIC_KEY=<same-value-as-VAPID_PUBLIC_KEY>
UI_PORT=8077
UI_HOST_PORT=8077

# ─────────────────────────────────────────────────────────────
# Envoy Proxy
# ─────────────────────────────────────────────────────────────
# Add `proxy` to COMPOSE_PROFILES to expose the app on local HTTP.
ENVOY_IMAGE=envoyproxy/envoy:v1.35-latest
ENVOY_HTTP_HOST_PORT=80

# ─────────────────────────────────────────────────────────────
# Cloudflare Tunnel
# ─────────────────────────────────────────────────────────────
# Add `tunnel` to COMPOSE_PROFILES and set this token to enable the connector.
TUNNEL_TOKEN=

# ─────────────────────────────────────────────────────────────
# Database Backup
# ─────────────────────────────────────────────────────────────
DBBACKUP_STORAGE_LOCATION=/vol/backups/
DBBACKUP_ADMINS=
DBBACKUP_EMAIL_SUBJECT_PREFIX='[Search Agent DB Backup]'

# ─────────────────────────────────────────────────────────────
# SearxNG Search
# ─────────────────────────────────────────────────────────────
SEARXNG_PORT=8080
SEARXNG_HOST_PORT=8888
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_PUBLIC_BASE_URL=http://localhost:8888/
SEARXNG_TIMEOUT_S=30

# ─────────────────────────────────────────────────────────────
# Crawl4AI
# ─────────────────────────────────────────────────────────────
CRAWL4AI_ENABLED=True
CRAWL4AI_HEADLESS=True
CRAWL4AI_MAX_PAGES_PER_RUN=25
CRAWL4AI_PRUNE_THRESHOLD=0.4
CRAWL4AI_WORD_COUNT_THRESHOLD=20
