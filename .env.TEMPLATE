# ─────────────────────────────────────────────────────────────
# Environment & Docker Compose
# ─────────────────────────────────────────────────────────────
APP_ENV=dev
COMPOSE_PROFILES=dev,celery
COMPOSE_FILE=docker-compose.yml
COMPOSE_PROJECT_NAME=search-agent
GIT_VERSION=
GIT_BRANCH=
GIT_LASTCOMMITDATE=

# ─────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=54377
POSTGRES_DB=search_agent
POSTGRES_USER=search_agent
POSTGRES_PASSWORD=secret

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379

# ─────────────────────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=fsex.settings
DJANGO_SECRET_KEY=kjsdhfkajsdhfkewiucjniuecniw-sldkjnejwrnvkjwrn-sodcnwojcnwijnc
DJANGO_DEBUG=True
DJANGO_LOG_LEVEL=DEBUG
DJANGO_LOG_SQL=False
DJANGO_PORT=5000
DJANGO_HOST_PORT=5077

# Security
DJANGO_ALLOWED_HOSTS=localhost,api,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8077,http://127.0.0.1:8077,http://api:5000
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8077,http://127.0.0.1:8077,http://api:5000
DJANGO_SITE_ID=1
DJANGO_SESSION_COOKIE_SAMESITE=Lax

# Superuser (created on first run)
DJANGO_SU_NAME=admin
DJANGO_SU_EMAIL=
DJANGO_SU_PASSWORD=admin

# Social Auth
# Google local callbacks:
#   http://localhost:8077/api/v1/auth/social/google/login/callback/
SOCIAL_AUTH_PUBLIC_BASE_URL=http://localhost:8077
SOCIAL_AUTH_GOOGLE_CLIENT_ID=
SOCIAL_AUTH_GOOGLE_CLIENT_SECRET=
SOCIAL_AUTH_GOOGLE_CLIENT_KEY=
SOCIAL_AUTH_GITHUB_CLIENT_ID=
SOCIAL_AUTH_GITHUB_CLIENT_SECRET=
SOCIAL_AUTH_GITHUB_CLIENT_KEY=
SOCIAL_AUTH_MICROSOFT_CLIENT_ID=
SOCIAL_AUTH_MICROSOFT_CLIENT_SECRET=
SOCIAL_AUTH_MICROSOFT_CLIENT_KEY=
SOCIAL_AUTH_MICROSOFT_TENANT=common

# ─────────────────────────────────────────────────────────────
# Frontend (Nuxt)
# ─────────────────────────────────────────────────────────────
NUXT_PUBLIC_API_URL=
UI_PORT=8077
UI_HOST_PORT=8077

# ─────────────────────────────────────────────────────────────
# Cloudflare Tunnel
# ─────────────────────────────────────────────────────────────
# Add `tunnel` to COMPOSE_PROFILES and set this token to enable the connector.
TUNNEL_TOKEN=

# ─────────────────────────────────────────────────────────────
# Database Backup
# ─────────────────────────────────────────────────────────────
DBBACKUP_STORAGE_LOCATION=/vol/backups/
DBBACKUP_ADMINS=
DBBACKUP_EMAIL_SUBJECT_PREFIX='[Search Agent DB Backup]'

# ─────────────────────────────────────────────────────────────
# Reverse Proxy (SMNRP) - production only
# ─────────────────────────────────────────────────────────────
SMNRP_DOMAINS=localhost
SMNRP_UPSTREAMS=api:5000
SMNRP_UPSTREAM_PROTOCOL=http
SMNRP_LOCATIONS=/api/!http://targets/api/,/static/!/vol/web/static/,/media/!/vol/web/media/,/admin/!http://targets/admin/
SMNRP_HTTP_HOST_PORT=8088
SMNRP_HTTPS_HOST_PORT=443

# ─────────────────────────────────────────────────────────────
# SearxNG Search
# ─────────────────────────────────────────────────────────────
SEARXNG_PORT=8080
SEARXNG_HOST_PORT=8888
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_PUBLIC_BASE_URL=http://localhost:8888/
SEARXNG_TIMEOUT_S=30

# ─────────────────────────────────────────────────────────────
# Crawl4AI
# ─────────────────────────────────────────────────────────────
CRAWL4AI_ENABLED=True
CRAWL4AI_HEADLESS=True
CRAWL4AI_MAX_PAGES_PER_RUN=25
CRAWL4AI_PRUNE_THRESHOLD=0.4
CRAWL4AI_WORD_COUNT_THRESHOLD=20
