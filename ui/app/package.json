{
  "name": "app",
  "version": "0.0.1",
  "description": "Search Agent dashboard for SearxNG discovery and Crawl4AI parsing",
  "productName": "Research Search Agent",
  "author": "Aleksandar Bobic, Boris Simic, David Meyer, Akay Akbiyik",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "darwin",
        "linux"
      ],
      "cpu": [
        "arm64",
        "x64"
      ]
    }
  },
  "scripts": {
    "build": "nuxt build",
    "generate:api": "orval",
    "watch:openapi": "node /app/scripts/watch-openapi.mjs",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@nuxt/ui": "^4.3.0",
    "@nuxtjs/i18n": "^10.2.4",
    "@pinia/nuxt": "^0.11.3",
    "@tanstack/vue-query": "^5.64.0",
    "@types/dompurify": "^3.0.5",
    "@vueuse/nuxt": "^14.1.0",
    "dompurify": "^3.3.1",
    "marked": "^17.0.1",
    "@iconify-json/heroicons": "^1.2.1",
    "nuxt": "^4.2.2",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@tailwindcss/typography": "^0.5.15",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.0.0",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^25.0.3",
    "concurrently": "^9.2.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-vue": "^9.30.0",
    "orval": "^8.5.3",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "typescript": "^5.9.3"
  }
}
